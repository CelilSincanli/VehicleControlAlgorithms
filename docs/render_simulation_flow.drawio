        <mxCell id="402" parent="40" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;" value="─── Pure Pursuit ───&#xa;ComputeSteering(simVehicleState_)" vertex="1">
          <mxGeometry height="55" width="320" x="32.5" y="540" as="geometry" />
        </mxCell>
        <mxCell id="403" parent="40" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" value="Ld = lookahead_distance + lookahead_gain × |v|&#xa;(adaptive lookahead — grows with speed)" vertex="1">
          <mxGeometry height="55" width="320" x="32.5" y="615" as="geometry" />
        </mxCell>
        <mxCell id="404" parent="40" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" value="FindClosestWaypoint(state)&#xa;forward search, window = 40 waypoints" vertex="1">
          <mxGeometry height="55" width="320" x="32.5" y="690" as="geometry" />
        </mxCell>
        <mxCell id="405" parent="40" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" value="FindLookaheadPoint(state, closest, Ld)&#xa;walk path forward until dist(wp, pos) ≥ Ld" vertex="1">
          <mxGeometry height="55" width="320" x="32.5" y="765" as="geometry" />
        </mxCell>
        <mxCell id="406" parent="40" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" value="local_y = −dx·sin(ψ) + dy·cos(ψ)&#xa;cross-track error in vehicle frame" vertex="1">
          <mxGeometry height="55" width="320" x="32.5" y="840" as="geometry" />
        </mxCell>
        <mxCell id="407" parent="40" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;" value="δ = atan2( 2·L·local_y,  Ld² )&#xa;Pure Pursuit steering formula  →  return δ" vertex="1">
          <mxGeometry height="55" width="320" x="32.5" y="915" as="geometry" />
        </mxCell>
        <mxCell id="408" parent="40" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;" value="─── Kinematic Bicycle Model ───&#xa;KinematicBicycleModel::Step(state, ctrl, dt)" vertex="1">
          <mxGeometry height="60" width="320" x="32.5" y="990" as="geometry" />
        </mxCell>
        <mxCell id="409" parent="40" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" value="Clamp δ:  max_delta = (SW_max / ratio) × π/180&#xa;δ = clamp(δ, −max_delta, +max_delta)" vertex="1">
          <mxGeometry height="55" width="320" x="32.5" y="1070" as="geometry" />
        </mxCell>
        <mxCell id="410" parent="40" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" value="Kinematics (rear-axle reference):&#xa;dx = v·cos(ψ)     dy = v·sin(ψ)&#xa;dψ = v/L · tan(δ)  dv = accel − CA·v·|v|" vertex="1">
          <mxGeometry height="70" width="320" x="32.5" y="1145" as="geometry" />
        </mxCell>
        <mxCell id="411" parent="40" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" value="Euler integrate (forward):&#xa;x  += dx·dt       y  += dy·dt&#xa;ψ  += dψ·dt       v   = max(0, v + dv·dt)" vertex="1">
